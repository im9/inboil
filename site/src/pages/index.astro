<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>INBOIL</title>
  <style>
    body {
      margin: 0;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-family: system-ui, sans-serif;
      background: #1e2028;
      color: rgba(237, 232, 220, 0.85);
    }
    h1 { font-size: 2rem; letter-spacing: 0.08em; margin-bottom: 1rem; }
    .links { display: flex; gap: 1rem; }
    .links a {
      padding: 0.5rem 1.2rem;
      border: 1px solid rgba(237, 232, 220, 0.2);
      border-radius: 6px;
      color: rgba(237, 232, 220, 0.85);
      text-decoration: none;
      font-size: 0.9rem;
    }
    .links a:hover {
      background: rgba(237, 232, 220, 0.08);
    }
  </style>
</head>
<body>
  <h1>INBOIL</h1>
  <div class="links">
    <a id="docs-link" href="/docs/getting-started/first-beat/">Get Started</a>
  </div>
  <script is:inline>
    const a = document.getElementById('docs-link');
    if (/^ja/i.test(navigator.language)) {
      a.href = '/ja/docs/getting-started/first-beat/';
      a.textContent = 'はじめる';
    }
  </script>
</body>
</html>
