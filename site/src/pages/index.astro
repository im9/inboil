        <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
      </a>
      <a id="header-app" class="header-cta" href={appUrl}>Open App</a>
    </div>
  </header>

  <main id="main">
  <!-- ── Hero ── -->
  <div class="page">
    <!-- Hero geometric composition — Y2K brutalist shapes -->
    <svg class="hero-geo" viewBox="0 0 400 600" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <defs>
        <pattern id="gp-dots" width="8" height="8" patternUnits="userSpaceOnUse">
          <circle cx="4" cy="4" r="1.2" fill="#1E2028"/>
        </pattern>
        <pattern id="gp-stripes" width="6" height="6" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
          <line x1="0" y1="0" x2="0" y2="6" stroke="#1E2028" stroke-width="1"/>
        </pattern>
      </defs>

      <!-- Large border squares — background layer -->
      <rect x="120" y="180" width="90" height="90" fill="none" stroke="#1E2028" stroke-width="1.5"/>
      <rect x="240" y="120" width="70" height="70" fill="none" stroke="#1E2028" stroke-width="1"/>
      <rect x="60" y="440" width="80" height="80" fill="none" stroke="#1E2028" stroke-width="1.5"/>
      <rect x="300" y="460" width="65" height="65" fill="none" stroke="#1E2028" stroke-width="1"/>
      <!-- Striped-fill square -->
      <rect x="180" y="330" width="70" height="70" fill="url(#gp-stripes)" opacity="0.3"/>
      <!-- Rotated border square -->
      <rect x="0" y="0" width="50" height="50" fill="none" stroke="#1E2028" stroke-width="1" transform="translate(340,230) rotate(15)"/>

      <!-- 4-pointed star — large, upper area -->
      <path d="M200,40 L215,90 L260,100 L215,110 L200,160 L185,110 L140,100 L185,90 Z" fill="#1E2028"/>

      <!-- Starburst/radial — center-right -->
      <g transform="translate(310,200)">
        <circle r="4" fill="#1E2028"/>
        <line x1="0" y1="-30" x2="0" y2="30" stroke="#1E2028" stroke-width="1.5"/>
        <line x1="-30" y1="0" x2="30" y2="0" stroke="#1E2028" stroke-width="1.5"/>
        <line x1="-21" y1="-21" x2="21" y2="21" stroke="#1E2028" stroke-width="1"/>
        <line x1="-21" y1="21" x2="21" y2="-21" stroke="#1E2028" stroke-width="1"/>
        <line x1="0" y1="-22" x2="0" y2="22" stroke="#1E2028" stroke-width="0.5" transform="rotate(22.5)"/>
        <line x1="0" y1="-22" x2="0" y2="22" stroke="#1E2028" stroke-width="0.5" transform="rotate(67.5)"/>
      </g>

      <!-- Orbital ring — large -->
      <ellipse cx="200" cy="280" rx="100" ry="35" fill="none" stroke="#1E2028" stroke-width="1.5" transform="rotate(-20 200 280)"/>
      <circle cx="200" cy="280" r="8" fill="#1E2028"/>

      <!-- Flower/clover — 4 petals -->
      <g transform="translate(80,160)">
        <circle cx="0" cy="-14" r="12" fill="#1E2028"/>
        <circle cx="14" cy="0" r="12" fill="#1E2028"/>
        <circle cx="0" cy="14" r="12" fill="#1E2028"/>
        <circle cx="-14" cy="0" r="12" fill="#1E2028"/>
        <circle cx="0" cy="0" r="6" fill="#EDE8DC"/>
      </g>

      <!-- Crosshair — upper right -->
      <g transform="translate(340,80)">
        <circle r="20" fill="none" stroke="#1E2028" stroke-width="1.2"/>
        <circle r="8" fill="none" stroke="#1E2028" stroke-width="1"/>
        <line x1="-28" y1="0" x2="28" y2="0" stroke="#1E2028" stroke-width="0.8"/>
        <line x1="0" y1="-28" x2="0" y2="28" stroke="#1E2028" stroke-width="0.8"/>
      </g>

      <!-- Dot grid block -->
      <rect x="20" y="300" width="80" height="80" fill="url(#gp-dots)"/>

      <!-- Diamond -->
      <rect x="0" y="0" width="24" height="24" fill="#1E2028" transform="translate(320,340) rotate(45)"/>

      <!-- Crescent — left area -->
      <path d="M60,380 a35,35 0 1,1 0,60 a27,27 0 1,0 0,-60" fill="#1E2028"/>

      <!-- Wave line -->
      <path d="M30,240 Q60,220 90,240 Q120,260 150,240 Q180,220 210,240" fill="none" stroke="#1E2028" stroke-width="1.5"/>

      <!-- Small 4-point stars scattered -->
      <path d="M60,80 L65,92 L78,96 L65,100 L60,112 L55,100 L42,96 L55,92 Z" fill="#1E2028"/>
      <path d="M350,400 L354,410 L364,413 L354,416 L350,426 L346,416 L336,413 L346,410 Z" fill="#1E2028"/>

      <!-- Half-filled circle — right half filled -->
      <clipPath id="half-clip"><rect x="340" y="318" width="32" height="64"/></clipPath>
      <circle cx="340" cy="350" r="30" fill="none" stroke="#1E2028" stroke-width="1.5"/>
      <circle cx="340" cy="350" r="30" fill="#1E2028" clip-path="url(#half-clip)"/>

      <!-- Olive accent shapes -->
      <rect x="160" y="350" width="16" height="16" fill="#787845"/>
      <circle cx="280" cy="310" r="10" fill="#787845"/>

      <!-- Thin concentric circles — mid-right -->
      <circle cx="260" cy="460" r="35" fill="none" stroke="#1E2028" stroke-width="1"/>
      <circle cx="260" cy="460" r="24" fill="none" stroke="#1E2028" stroke-width="0.8"/>
      <circle cx="260" cy="460" r="13" fill="none" stroke="#1E2028" stroke-width="0.6"/>
      <circle cx="260" cy="460" r="3" fill="#1E2028"/>

      <!-- Downward arrow — center bottom -->
      <path d="M120,500 L120,530 L108,530 L130,555 L152,530 L140,530 L140,500 Z" fill="none" stroke="#1E2028" stroke-width="1.5"/>
      <!-- Shrinking chevrons below arrow -->
      <path d="M115,568 L130,580 L145,568" fill="none" stroke="#1E2028" stroke-width="1"/>
      <path d="M120,588 L130,596 L140,588" fill="none" stroke="#1E2028" stroke-width="0.7"/>

      <!-- Small decorative dots -->
      <circle cx="160" cy="60" r="3" fill="#1E2028"/>
      <circle cx="380" cy="150" r="3" fill="#1E2028"/>
      <circle cx="380" cy="480" r="3" fill="#1E2028"/>
      <circle cx="50" cy="320" r="2" fill="#1E2028"/>

      <!-- Plus signs -->
      <g transform="translate(30,140)">
        <line x1="-6" y1="0" x2="6" y2="0" stroke="#1E2028" stroke-width="2"/>
        <line x1="0" y1="-6" x2="0" y2="6" stroke="#1E2028" stroke-width="2"/>
      </g>
      <g transform="translate(370,300)">
        <line x1="-5" y1="0" x2="5" y2="0" stroke="#1E2028" stroke-width="1.5"/>
        <line x1="0" y1="-5" x2="0" y2="5" stroke="#1E2028" stroke-width="1.5"/>
