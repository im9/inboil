      dragOffX = p.x - n.x;
      dragOffY = p.y - n.y;
      g.style.cursor = 'grabbing';
    });

    svg.addEventListener('pointermove', e => {
      if (!dragNode) return;
      const p = svgPoint(e);
      dragNode.x = Math.max(0, Math.min(720 - NW, p.x - dragOffX));
      dragNode.y = Math.max(0, Math.min(240 - NH, p.y - dragOffY));
