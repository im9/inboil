    svg.addEventListener('pointerup', () => {
      if (dragNode) {
        const g = nodesG.querySelector(`[data-node="${dragNode.id}"]`);
        if (g) g.style.cursor = 'grab';
      }
      dragNode = null;
    });

    svg.addEventListener('pointercancel', () => { dragNode = null; });
  })();

  // ── FX Pad constellation demo ──
  (() => {
    const demo = document.getElementById('fx-demo');
    const canvas = document.getElementById('fx-canvas');
    if (!demo || !canvas) return;
    const ctx2d = canvas.getContext('2d');
    const nodes = demo.querySelectorAll('.fx-node');
    let W, H;

    function resize() {
      const r = demo.getBoundingClientRect();
      W = r.width; H = r.height;
      canvas.width = W * devicePixelRatio;
      canvas.height = H * devicePixelRatio;
      ctx2d.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize);

    // Toggle on click
    nodes.forEach(n => {
      n.addEventListener('click', e => {
        if (n._dragged) return;
        n.classList.toggle('on');
      });
    });

    // Drag
    let dragEl = null, ox, oy;
    demo.addEventListener('pointerdown', e => {
      const n = e.target.closest('.fx-node');
      if (!n) return;
      e.preventDefault();
      n._dragged = false;
      dragEl = n;
      const r = demo.getBoundingClientRect();
      ox = e.clientX - (parseFloat(n.style.left) / 100 * r.width);
      oy = e.clientY - (parseFloat(n.style.top) / 100 * r.height);
      demo.setPointerCapture(e.pointerId);
    });
    demo.addEventListener('pointermove', e => {
      if (!dragEl) return;
      dragEl._dragged = true;
      const r = demo.getBoundingClientRect();
      const x = Math.max(0, Math.min(100, (e.clientX - ox) / r.width * 100));
      const y = Math.max(0, Math.min(100, (e.clientY - oy) / r.height * 100));
      dragEl.style.left = x + '%';
      dragEl.style.top = y + '%';
    });
    demo.addEventListener('pointerup', () => { dragEl = null; });
    demo.addEventListener('pointercancel', () => { dragEl = null; });

    // Draw constellation lines
    let t = 0;
    function draw() {
      requestAnimationFrame(draw);
      t += 0.02;
      ctx2d.clearRect(0, 0, W, H);
      const pts = [];
      nodes.forEach(n => {
        pts.push({
          x: parseFloat(n.style.left) / 100 * W,
          y: parseFloat(n.style.top) / 100 * H,
          on: n.classList.contains('on'),
          color: n.style.color
        });
      });
      // Ghost lines between all pairs
      for (let i = 0; i < pts.length; i++) {
        for (let j = i + 1; j < pts.length; j++) {
          const a = pts[i], b = pts[j];
          ctx2d.beginPath();
          ctx2d.moveTo(a.x, a.y);
          ctx2d.lineTo(b.x, b.y);
          ctx2d.strokeStyle = 'rgba(237,232,220,0.04)';
          ctx2d.lineWidth = 1;
          ctx2d.stroke();
          // Active glow between enabled nodes
          if (a.on && b.on) {
            const wave = Math.sin(t + i * 1.3 + j * 0.7) * 0.3 + 0.7;
            ctx2d.beginPath();
            ctx2d.moveTo(a.x, a.y);
            ctx2d.lineTo(b.x, b.y);
            ctx2d.strokeStyle = `rgba(237,232,220,${0.08 * wave})`;
            ctx2d.lineWidth = 2;
            ctx2d.stroke();
          }
        }
      }
    }
    draw();
  })();
  </script>
</body>
</html>
