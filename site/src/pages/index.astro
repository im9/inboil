---
import pkg from '../../../package.json';
const appUrl = import.meta.env.DEV ? 'http://localhost:5173' : (import.meta.env.PUBLIC_APP_URL || 'https://inboil.pages.dev');
const siteUrl = import.meta.env.DEV ? 'http://localhost:4321' : (import.meta.env.SITE || 'https://inboil.pages.dev');
const description = 'A browser-based groove box with 19 sound engines, a graphical sequencer, and zero setup. No install. No signup. Just play.';
const ogImage = `${siteUrl}/og.png`;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <script is:inline>if(localStorage.getItem('inboil-lang')==='ja'||(!localStorage.getItem('inboil-lang')&&/^ja/i.test(navigator.language)))document.documentElement.lang='ja';</script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#1E2028" />
  <title>INBOIL — A groove box in your browser</title>
  <meta name="description" content={description} />
  <!-- OGP -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content="INBOIL — A groove box in your browser" />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="INBOIL — A groove box in your browser" />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="canonical" href={siteUrl} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:locale:alternate" content="ja_JP" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" /></noscript>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "INBOIL",
    "url": siteUrl,
    "applicationCategory": "MultimediaApplication",
    "operatingSystem": "Web browser",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "description": description,
    "screenshot": ogImage,
    "browserRequirements": "Requires Web Audio API and AudioWorklet support",
  })} />
  <style is:global>
    *{margin:0;padding:0;box-sizing:border-box}
    html,body{
      width:100%;
      overflow-x:hidden;
      /* SceneCanvas と同じ: cream + 40px grid */
      background-color:#EDE8DC;
      background-image:
        linear-gradient(rgba(30,32,40,0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(30,32,40,0.06) 1px, transparent 1px);
      background-size:40px 40px;
    }

    /* ── Logo flap ── */
    @keyframes flap{
      0%{transform:perspective(80px) rotateY(0)}
      40%{transform:perspective(80px) rotateY(180deg)}
      100%{transform:perspective(80px) rotateY(360deg)}
    }
    .logo-flap .flap-cell{
      transform-origin:center;
      transform-box:fill-box;
      animation:flap 0.6s ease-in-out calc(var(--i) * 0.12s) both;
    }
    .logo-flap:hover .flap-cell{
      animation:flap 0.6s ease-in-out calc(var(--i) * 0.12s);
    }

    .page{
      display:flex;
      flex-direction:column;
      align-items:flex-start;
      justify-content:center;
      gap:68px;
      padding:120px 48px 140px;
      padding-left:max(48px, 8vw);
      text-align:left;
      position:relative;
      max-width:1400px;
      margin:0 auto;
      width:100%;
    }
    .hero-geo{
      position:absolute;
      top:40px;right:0;
      width:45%;
      height:calc(100% + 40px);
      pointer-events:none;
    }
    @media(max-width:768px){
      .hero-geo{display:none}
      .page{
        padding:80px 24px 32px;
        gap:32px;
        align-items:center;
        text-align:center;
      }
      .hero-visual{min-width:0}
      .hero-text{align-items:center}
      .tagline{white-space:normal;font-size:1.5rem}
      .cta{padding:0.6rem 1.4rem;font-size:0.85rem}
      .cta-row{flex-wrap:wrap}
    }
    .hero-text{
      display:flex;flex-direction:column;
      align-items:flex-start;
      position:relative;
      z-index:1;
    }
    .brand{
      display:flex;align-items:center;gap:20px;
      margin-bottom:16px;
    }
    .brand svg{width:clamp(64px, 10vw, 96px);height:clamp(64px, 10vw, 96px);flex-shrink:0}
    .brand h1{
      font-family:"JetBrains Mono",monospace;
      font-size:clamp(4rem, 10vw, 7rem);letter-spacing:0.12em;
      text-transform:uppercase;
      color:#1E2028;
      font-weight:700;
    }
    .tagline{
      font-family:system-ui, -apple-system, sans-serif;
      font-size:clamp(1.5rem, 2.4vw, 2.2rem);letter-spacing:-0.01em;
      white-space:nowrap;
      color:rgba(30,32,40,0.8);
      line-height:1.2;
      margin-bottom:8px;
    }
    .hero-sub{
      font-family:"JetBrains Mono",monospace;
      font-size:0.8rem;letter-spacing:0.04em;
      color:rgba(30,32,40,0.55);
      margin-bottom:28px;
    }
    .hero-visual{
      display:flex;flex-direction:column;
      align-items:flex-start;
      gap:8px;
      width:100%;
      max-width:640px;
      position:relative;
      z-index:1;
    }

    /* ── Sequencer grid ── */
    .seq-wrap{
      margin-bottom:6px;
      touch-action:none;
      user-select:none;
      width:100%;
      max-width:100%;
    }
    .seq-row{
      display:flex;align-items:center;gap:2px;
      margin-bottom:2px;
    }
    .seq-row:last-child{margin-bottom:0}
    .seq-label{
      width:48px;
      font-family:"JetBrains Mono",monospace;
      font-size:11px;font-weight:700;
      letter-spacing:0.04em;
      text-align:right;
      padding-right:8px;
      color:#1E2028;
      flex-shrink:0;
    }
    @media(max-width:639px){
      .seq-label{width:36px;font-size:9px;padding-right:6px}
    }

    /* Othello flip — flexible sizing to fill container */
    button.step{
      appearance:none;
      border:none;
      background:none;
      padding:0;margin:0;
      position:relative;
      flex:1;
      min-width:0;
      aspect-ratio:1;
      cursor:pointer;
      perspective:80px;
      max-width:48px;max-height:48px;
    }
    .step .flip-card{
      width:100%;height:100%;
      position:relative;
      transform-style:preserve-3d;
      transition:transform 180ms ease-out;
    }
    .step.active .flip-card{transform:rotateY(180deg)}
    .step:active .flip-card{transform:scale(0.85)}
    .step.active:active .flip-card{transform:rotateY(180deg) scale(0.85)}
    .step .flip-face{
      position:absolute;
      top:0;left:0;right:0;bottom:0;
      backface-visibility:hidden;
    }
    .step .flip-face.front{
      background:#EDE8DC;
      border:1px solid rgba(30,32,40,0.35);
    }
    .step .flip-face.back{
      transform:rotateY(180deg);
      background:#787845;
    }

    /* Playhead: active cell flashes bright */
    @keyframes ph-glow{
      0%{filter:brightness(1.6)}
      100%{filter:brightness(1)}
    }
    .step.playhead.active .flip-face.back{
      animation:ph-glow 180ms ease-out;
    }
    /* Playhead: inactive cell flashes white */
    @keyframes ph-off{
      0%{background:rgba(255,255,255,0.9)}
      100%{background:#EDE8DC}
    }
    .step.playhead:not(.active) .flip-face.front{
      animation:ph-off 180ms ease-out;
    }

    /* ── Controls ── */
    .sound-toggle{
      appearance:none;
      border:1.5px solid #787845;
      border-radius:0;
      background:transparent;
      padding:4px 8px;margin:0;
      cursor:pointer;
      display:flex;align-items:center;gap:6px;
      color:#787845;
      font-family:"JetBrains Mono",monospace;
      font-size:9px;font-weight:700;
      letter-spacing:0.04em;
      text-transform:uppercase;
    }
    .sound-toggle.active{
      background:#787845;
      border-color:#787845;
      color:#EDE8DC;
    }
    .cta-row{
      display:flex;gap:1.2rem;
      max-width:420px;
    }
    .cta{
      padding:0.75rem 2.4rem;
      border:1.5px solid rgba(30,32,40,0.25);
      border-radius:0;
      background:transparent;
      color:rgba(30,32,40,0.6);
      font-family:"JetBrains Mono",monospace;
      font-size:1rem;letter-spacing:0.06em;
      text-transform:uppercase;text-decoration:none;
      white-space:nowrap;
    }
    .cta:hover{
      background:rgba(30,32,40,0.04);
      border-color:rgba(30,32,40,0.35);
      color:rgba(30,32,40,0.7);
    }
    .cta.primary{
      background:#787845;
      border-color:#787845;
      color:#EDE8DC;
      position:relative;
      overflow:hidden;
    }
    .cta.primary::after{
      content:'';
      position:absolute;
      top:0;left:-100%;
      width:100%;height:100%;
      background:linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
      transition:none;
    }
    .cta.primary:hover::after{
      left:100%;
      transition:left 0.5s ease;
    }
    .cta.primary:hover{
      background:#8a8a50;
      border-color:#8a8a50;
    }

    /* ── Section geo decorations ── */
    .section-geo{
      position:absolute;
      pointer-events:none;
      z-index:2;
    }
    .section-geo-mobile{
      display:none;
      position:absolute;
      pointer-events:none;
      z-index:2;
      top:-18px;
    }
    @media(max-width:768px){
      .section-geo{display:none}
      .section-geo-mobile{display:block}
    }

    /* ── Feature sections ── */
    .feat-section{
      width:100%;
      padding:120px 48px;
      display:grid;
      grid-template-columns:2fr 3fr;
      align-items:start;
      gap:48px;
      position:relative;
      overflow:visible;
    }
    .feat-section:nth-child(even){background:rgba(30,32,40,0.03)}
    /* 奇数: テキスト上、ビジュアル下げる */
    .feat-section .feat-text{padding-top:0}
    .feat-section .feat-visual{padding-top:clamp(60px, 10vw, 120px)}
    /* 偶数: レイアウト反転（ビジュアル左・テキスト右）+ ずらし逆 */
    .feat-scene-body{
      grid-column:1/-1;
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:32px;
      align-items:start;
    }
    .feat-section:nth-child(even){grid-template-columns:3fr 2fr}
    .feat-section:nth-child(even) .feat-text{order:2;padding-top:0}
    .feat-section:nth-child(even) .feat-visual{order:1;padding-top:clamp(80px, 16vw, 200px)}
    /* フルワイド variant (FX Pad) */
    .feat-section.full{
      grid-template-columns:1fr;
      text-align:center;
      gap:48px;
    }
    .feat-section.full .feat-text{align-items:center;padding-top:0}
    .feat-section.full .feat-visual{justify-content:center;padding-top:0}
    @media(max-width:768px){
      .feat-section{
        grid-template-columns:1fr;
        padding:64px 24px;
        gap:48px;
      }
      .feat-text{min-width:0}
      .feat-scene-body{grid-template-columns:1fr}
      .feat-section .feat-visual{padding-top:0;min-width:0}
      .feat-section:nth-child(even){grid-template-columns:1fr}
      .feat-section:nth-child(even) .feat-text{order:0;padding-top:0}
      .feat-section:nth-child(even) .feat-visual{order:0;padding-top:0}
      .voice-chip{width:48px;height:44px}
      .v-label{font-size:10px}
      .v-name{font-size:8px}
      .feat-section.full{text-align:left}
      .feat-section.full .feat-text{align-items:flex-start}
    }
    .feat-text{
      display:flex;flex-direction:column;
      gap:20px;
    }
    .feat-title{
      font-family:"JetBrains Mono",monospace;
      font-size:clamp(3.5rem, 8vw, 7rem);font-weight:700;
      letter-spacing:0.04em;
      text-transform:uppercase;
      color:#1E2028;
      line-height:1;
      white-space:nowrap;
    }
    @media(max-width:768px){
      .feat-title{white-space:normal;font-size:clamp(2rem, 10vw, 3.5rem)}
    }
    /* タイトル下のアクセントライン */
    .feat-title::after{
      content:'';
      display:block;
      width:48px;height:3px;
      background:#787845;
      margin-top:12px;
    }
    .feat-section.full .feat-title::after{margin-left:auto;margin-right:auto}
    /* Feature title accent line bounce on hover */
    .feat-title{transition:transform 0.2s ease}
    .feat-title:hover{transform:translateY(-2px)}
    @keyframes accent-pulse{
      0%,100%{width:48px}
      50%{width:64px}
    }
    .feat-title:hover::after{
      animation:accent-pulse 0.4s ease;
    }
    .feat-desc{
      font-family:system-ui, -apple-system, sans-serif;
      font-size:0.95rem;
      line-height:2;
      color:rgba(30,32,40,0.7);
      letter-spacing:0.01em;
    }
    .feat-visual{
      display:flex;
      align-items:center;
      justify-content:center;
      min-width:0;
    }

    /* ── Voice grid ── */
    .voice-grid{
      display:flex;flex-wrap:wrap;
      gap:2px;
      justify-content:flex-start;
      max-width:100%;
    }
    .voice-chip{
      display:flex;flex-direction:column;
      align-items:center;justify-content:center;
      width:56px;height:44px;
      background:transparent;
      border:1px solid rgba(30,32,40,0.3);
      font-family:"JetBrains Mono",monospace;
      transition:all 120ms;
      cursor:default;
    }
    .voice-chip.hl{
      background:#787845;
      border-color:#787845;
    }
    .voice-chip.hl .v-label,
    .voice-chip.hl .v-name{color:#EDE8DC}
    .v-label{
      font-size:11px;font-weight:700;
      letter-spacing:0.04em;
      color:#1E2028;
    }
    .v-name{
      font-size:9px;
      color:rgba(30,32,40,0.55);
      letter-spacing:0.02em;
    }
    .voice-sep{
      width:100%;height:0;
      flex-basis:100%;
    }

    /* ── Interactive engine viewer ── */
    .engine-viewer{
      width:100%;
      margin-top:40px;
      background:#1E2028;
      border-radius:0;
      padding:20px 24px;
      box-shadow:0 12px 48px rgba(0,0,0,0.25), 0 0 0 1px rgba(30,32,40,0.15);
      font-family:"JetBrains Mono",monospace;
    }
    .ev-header{
      display:flex;align-items:center;justify-content:space-between;
      margin-bottom:16px;
    }
    .ev-voice-name{
      font-size:15px;font-weight:700;letter-spacing:0.06em;
      color:rgba(237,232,220,0.82);text-transform:uppercase;
    }
    .ev-voice-cat{
      font-size:10px;font-weight:700;letter-spacing:0.06em;
      color:rgba(237,232,220,0.35);
    }
    .ev-graph-area{
      width:100%;
      border-radius:3px;
      background:rgba(0,0,0,0.25);
      margin-bottom:16px;
      position:relative;
      overflow:hidden;
    }
    .ev-graph-area svg{width:100%;height:auto;display:block}
    .ev-knobs{
      display:flex;
      gap:20px;
      justify-content:center;
      flex-wrap:wrap;
      padding:4px 0;
    }
    .ev-knob{
      display:flex;flex-direction:column;align-items:center;
      cursor:ns-resize;touch-action:none;user-select:none;
    }
    .ev-knob svg{width:52px;height:52px}
    @media(max-width:768px){
      .ev-knobs{gap:12px}
      .ev-knob svg{width:44px;height:44px}
      .engine-viewer{padding:16px 16px}
    }
    .ev-knob-label{
      font-size:9px;font-weight:700;letter-spacing:0.06em;
      color:rgba(237,232,220,0.4);text-transform:uppercase;
      margin-top:2px;
    }

    /* ── Graphical Sequencer SVG ── */
    .scene-demo{width:100%;max-width:640px;touch-action:none}
    @keyframes scene-pulse{
      0%{filter:brightness(1.3)}
      100%{filter:brightness(1)}
    }
    .sn-playing{animation:scene-pulse 0.5s ease-out infinite alternate}

    /* ── FX Pad demo ── */
    .fx-demo{
      width:100%;max-width:600px;aspect-ratio:1;
      background:#1E2028;
      border-radius:0;
      position:relative;
      overflow:hidden;
      touch-action:none;
      user-select:none;
      cursor:crosshair;
      box-shadow:0 12px 48px rgba(0,0,0,0.25), 0 0 0 1px rgba(30,32,40,0.15);
    }
    .fx-demo canvas{position:absolute;top:0;left:0;width:100%;height:100%}
    .fx-node{
      position:absolute;width:48px;height:48px;
      border-radius:50%;
      display:flex;align-items:center;justify-content:center;
      font-family:"JetBrains Mono",monospace;
      font-size:10px;font-weight:700;letter-spacing:0.04em;
      /* inactive: transparent bg, colored border & text */
      color:var(--node-color);
      background:transparent;
      border:2px solid var(--node-color);
      cursor:grab;
      transform:translate(-50%,-50%);
      transition:box-shadow 0.2s, background 0.2s;
    }
    .fx-node:active{cursor:grabbing}
    .fx-node:focus-visible{outline:2px solid var(--node-color);outline-offset:2px}
    /* active: solid fill, inverted text */
    .fx-node.on{
      background:var(--node-color);
      color:#EDE8DC;
      box-shadow:0 0 16px var(--node-color);
    }

    /* ── Generative demo (SVG, same visual language as scene-svg) ── */


    /* voice chip hover + focus */
    .voice-chip{cursor:pointer}
    .voice-chip:hover,
    .voice-chip:focus-visible{
      background:rgba(120,120,69,0.1);
      border-color:rgba(120,120,69,0.4);
    }
    .voice-chip:focus-visible{
      outline:2px solid #787845;
      outline-offset:1px;
    }

    /* ── Header — docs header と同じ navy bg / cream text ── */
    .site-header{
      position:fixed;top:0;left:0;right:0;
      z-index:100;
      padding:12px 24px;
      background:#1E2028;
      display:flex;
      align-items:center;
      justify-content:space-between;
      font-family:"JetBrains Mono",monospace;
    }
    .header-brand{
      display:flex;align-items:center;gap:8px;
      font-size:0.7rem;
      font-weight:700;letter-spacing:0.12em;
      text-transform:uppercase;
      color:#EDE8DC;
      text-decoration:none;
    }
    .header-links{display:flex;gap:1.5rem;align-items:center}
    .header-links a{
      color:rgba(237,232,220,0.5);
      text-decoration:none;
      text-transform:uppercase;
      font-size:0.7rem;
      letter-spacing:0.04em;
      transition:color 0.2s;
    }
    .header-links a:hover{color:#EDE8DC}
    .header-links .header-cta{
      background:#6C7744;
      color:#EDE8DC;
      padding:5px 14px;
      font-weight:700;
      transition:background 0.2s;
    }
    .header-links .header-cta:hover{
      background:#7a8a4e;
      color:#EDE8DC;
    }
    .lang-toggle{
      background:transparent;
      border:1px solid rgba(237,232,220,0.3);
      color:rgba(237,232,220,0.5);
      font-family:"JetBrains Mono",monospace;
      font-size:0.65rem;
      font-weight:700;
      letter-spacing:0.08em;
      padding:2px 8px;
      cursor:pointer;
      transition:all 0.2s;
    }
    .lang-toggle:hover{
      color:#EDE8DC;
      border-color:rgba(237,232,220,0.6);
    }

    /* ── Story + Support ── */
    .story-section{
      width:100%;
      padding:96px 48px;
      display:flex;
      justify-content:center;
      position:relative;
      overflow:visible;
    }
    .story-content{
      max-width:560px;
      display:flex;flex-direction:column;
      gap:40px;
    }
    .story-group{
      display:flex;flex-direction:column;
      gap:20px;
      border-left:3px solid #787845;
      padding-left:24px;
    }
    .story-heading{
      font-family:"JetBrains Mono",monospace;
      font-size:clamp(1.6rem, 3.5vw, 2.2rem);
      font-weight:700;
      letter-spacing:0.06em;
      color:#1E2028;
    }
    .story-body{
      font-family:system-ui, -apple-system, sans-serif;
      font-size:0.95rem;
      line-height:2;
      color:rgba(30,32,40,0.7);
    }
    .donate-cta{
      align-self:center;
      margin-top:8px;
      border-color:#787845;
      color:#787845;
      font-weight:700;
    }
    .donate-cta:hover{
      background:#787845;
      color:#EDE8DC;
    }
    .donate-heart{
      font-size:1.1em;
      transition:transform 0.3s;
    }
    .donate-cta:hover .donate-heart{
      transform:scale(1.3);
    }
    @media(max-width:768px){
      .story-section{padding:64px 24px}
    }

    /* ── Specs ── */
    .specs-section{
      width:100%;
      padding:96px 48px;
      position:relative;
      overflow:visible;
    }
    .specs-title{
      font-family:"JetBrains Mono",monospace;
      font-size:clamp(2rem, 5vw, 3.5rem);
      font-weight:700;
      letter-spacing:0.04em;
      text-transform:uppercase;
      color:#1E2028;
      margin-bottom:48px;
    }
    .specs-grid{
      display:grid;
      grid-template-columns:repeat(auto-fill, minmax(240px, 1fr));
      gap:1px;
      background:rgba(30,32,40,0.08);
      border:1px solid rgba(30,32,40,0.08);
    }
    .spec-cell{
      background:#EDE8DC;
      padding:20px 24px;
    }
    .spec-label{
      font-family:"JetBrains Mono",monospace;
      font-size:10px;
      font-weight:700;
      letter-spacing:0.08em;
      text-transform:uppercase;
      color:rgba(30,32,40,0.6);
      margin-bottom:6px;
    }
    .spec-value{
      font-family:"JetBrains Mono",monospace;
      font-size:1.4rem;
      font-weight:700;
      color:#1E2028;
      line-height:1.2;
    }
    .spec-note{
      font-family:system-ui, -apple-system, sans-serif;
      font-size:0.8rem;
      color:rgba(30,32,40,0.6);
      margin-top:4px;
    }
    @media(max-width:768px){
      .specs-section{padding:64px 24px}
      .specs-grid{grid-template-columns:repeat(3, 1fr)}
    }
    @media(max-width:480px){
      .specs-grid{grid-template-columns:1fr 1fr}
    }

    /* ── Final CTA ── */
    .final-cta{
      width:100%;
      padding:96px 48px;
      display:flex;flex-direction:column;
      align-items:center;
      background:#1E2028;
      gap:24px;
      text-align:center;
      position:relative;
      overflow:visible;
      z-index:0;
    }
    .cta-geo{
      position:absolute;
      pointer-events:none;
      opacity:0.35;
      z-index:2;
    }
    .cta-geo-mobile-wrap{display:none}
    @media(max-width:1100px){
      .cta-geo{display:none}
    }
    @media(max-width:768px){
      .cta-geo-mobile-wrap{
        display:block;
        position:absolute;
        left:0;top:0;
        width:100%;height:100%;
        pointer-events:none;
        overflow:visible;
      }
      .cta-geo-m{
        position:absolute;
        pointer-events:none;
        opacity:0.25;
      }
    }
    .final-cta-heading{
      font-family:"JetBrains Mono",monospace;
      font-size:clamp(1.8rem, 4vw, 3rem);
      font-weight:700;
      letter-spacing:0.06em;
      color:#EDE8DC;
    }
    .final-cta-sub{
      font-family:system-ui, -apple-system, sans-serif;
      font-size:0.95rem;
      color:rgba(237,232,220,0.6);
      letter-spacing:0.01em;
    }
    .final-cta .cta{
      border-color:rgba(237,232,220,0.25);
      color:rgba(237,232,220,0.6);
    }
    .final-cta .cta:hover{
      background:rgba(237,232,220,0.08);
      border-color:rgba(237,232,220,0.4);
      color:#EDE8DC;
    }
    .final-cta .cta.primary{
      background:#787845;
      border-color:#787845;
      color:#EDE8DC;
    }
    .final-cta .cta.primary:hover{
      background:#8a8a50;
      border-color:#8a8a50;
    }
    @media(max-width:768px){
      .final-cta{padding:64px 24px}
    }

    /* ── Reduced motion ── */
    @media(prefers-reduced-motion: reduce){
      .logo-flap .flap-cell{animation:none}
      .logo-flap:hover .flap-cell{animation:none}
      .step .flip-card{transition:none}
      .step.playhead.active .flip-face.back{animation:none}
      .step.playhead:not(.active) .flip-face.front{animation:none}
      .feat-title:hover::after{animation:none}
      .sn-playing{animation:none}
      .cta.primary::after{transition:none}
      .donate-heart{transition:none}
    }

    /* ── Screen-reader only ── */
    .sr-only{
      position:absolute;width:1px;height:1px;
      padding:0;margin:-1px;overflow:hidden;
      clip:rect(0,0,0,0);white-space:nowrap;border:0;
    }

    /* ── Skip link ── */
    .skip-link{
      position:absolute;
      top:-100%;left:50%;
      transform:translateX(-50%);
      padding:0.5rem 1.2rem;
      background:#1E2028;color:#EDE8DC;
      font-family:"JetBrains Mono",monospace;
      font-size:0.75rem;letter-spacing:0.04em;
      text-decoration:none;
      z-index:200;
      border-radius:0 0 4px 4px;
    }
    .skip-link:focus{top:0}

    /* ── Footer ── */
    .footer{
      width:100%;
      padding:16px 24px;
      text-align:center;
      font-family:"JetBrains Mono",monospace;
      font-size:0.65rem;
      letter-spacing:0.04em;
      color:rgba(30,32,40,0.45);
    }
    .footer-version{
      opacity:0.7;
    }
  </style>
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <!-- ── Header ── -->
  <header class="site-header">
    <a class="header-brand" href="/">
      <svg viewBox="0 0 32 32" aria-hidden="true" width="18" height="18">
        <rect width="32" height="32" rx="4" fill="#1e2028"/>
