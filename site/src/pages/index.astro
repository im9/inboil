          bar1.setAttribute('x', String(bx - bw - bg/2));
          bar1.setAttribute('y', String(by - bh/2));
          bar1.setAttribute('width', String(bw));
          bar1.setAttribute('height', String(bh));
          bar1.setAttribute('rx', '0.8');
          bar1.setAttribute('fill', '#1E2028');
