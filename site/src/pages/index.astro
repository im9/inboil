          <path d="M4 10.5V8.5a5 5 0 0110 0v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <rect x="2" y="10" width="3" height="4" rx="1" fill="currentColor"/>
          <rect x="13" y="10" width="3" height="4" rx="1" fill="currentColor"/>
