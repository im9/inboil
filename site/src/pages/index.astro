        <span class="sound-label">Sound</span>
      </button>
    </div>
  </div>

  <!-- ── Feature 1: Voices ── -->
  <section class="feat-section">
    <!-- (B0 composition moved to story section) -->
    <!-- B0 mobile -->
    <svg class="section-geo-mobile" style="right:20px" viewBox="0 0 72 48" width="72" height="48" aria-hidden="true">
      <path d="M18,4 a14,14 0 1,1 0,24 a11,11 0 1,0 0,-24" fill="#1E2028"/>
      <path d="M50,10 L53,20 L63,23 L53,26 L50,36 L47,26 L37,23 L47,20 Z" fill="#1E2028"/>
      <circle cx="30" cy="42" r="2" fill="#1E2028"/>
    </svg>
    <div class="feat-text">
      <h2 id="feat-voice-title" class="feat-title">Sound Engines</h2>
      <p id="feat-voice-desc" class="feat-desc">20 voices — from drum machines to FM percussion and wavetable synths, plus a polyphonic sampler with 90 built-in samples and a multi-sampled grand piano. Choose a different engine for each track.</p>
      <!-- Voice grid selector -->
      <div class="voice-grid">
        <div class="voice-chip" data-v="909k" role="button" tabindex="0" aria-label="909 Kick"><span class="v-label">909K</span><span class="v-name">909 Kick</span></div>
        <div class="voice-chip" data-v="808k" role="button" tabindex="0" aria-label="808 Kick"><span class="v-label">808K</span><span class="v-name">808 Kick</span></div>
        <div class="voice-chip" data-v="snare" role="button" tabindex="0" aria-label="Snare"><span class="v-label">SNARE</span><span class="v-name">Snare</span></div>
        <div class="voice-chip" data-v="clap" role="button" tabindex="0" aria-label="Clap"><span class="v-label">CLAP</span><span class="v-name">Clap</span></div>
        <div class="voice-chip" data-v="chh" role="button" tabindex="0" aria-label="Closed Hi-Hat"><span class="v-label">C.HH</span><span class="v-name">Closed HH</span></div>
        <div class="voice-chip" data-v="ohh" role="button" tabindex="0" aria-label="Open Hi-Hat"><span class="v-label">O.HH</span><span class="v-name">Open HH</span></div>
        <div class="voice-chip" data-v="cym" role="button" tabindex="0" aria-label="Cymbal"><span class="v-label">CYM</span><span class="v-name">Cymbal</span></div>
        <div class="voice-chip" data-v="tom" role="button" tabindex="0" aria-label="Tom"><span class="v-label">TOM</span><span class="v-name">Tom</span></div>
        <div class="voice-chip" data-v="rim" role="button" tabindex="0" aria-label="Rimshot"><span class="v-label">RIM</span><span class="v-name">Rimshot</span></div>
        <div class="voice-chip" data-v="bell" role="button" tabindex="0" aria-label="Cowbell"><span class="v-label">BELL</span><span class="v-name">Cowbell</span></div>
        <div class="voice-chip" data-v="shkr" role="button" tabindex="0" aria-label="Shaker"><span class="v-label">SHKR</span><span class="v-name">Shaker</span></div>
        <div class="voice-chip" data-v="fmd" role="button" tabindex="0" aria-label="FM Drum"><span class="v-label">FMD</span><span class="v-name">FM Drum</span></div>
        <div class="voice-chip" data-v="303" role="button" tabindex="0" aria-label="Bass 303"><span class="v-label">303</span><span class="v-name">Bass 303</span></div>
        <div class="voice-chip" data-v="bass" role="button" tabindex="0" aria-label="Analog Bass"><span class="v-label">BASS</span><span class="v-name">Analog</span></div>
        <div class="voice-chip" data-v="lead" role="button" tabindex="0" aria-label="Synth Lead"><span class="v-label">LEAD</span><span class="v-name">Synth</span></div>
        <div class="voice-chip" data-v="fm" role="button" tabindex="0" aria-label="FM Synth"><span class="v-label">FM</span><span class="v-name">FM Synth</span></div>
        <div class="voice-chip hl" data-v="wave" role="button" tabindex="0" aria-label="Wavetable"><span class="v-label">WAVE</span><span class="v-name">Wavetable</span></div>
        <div class="voice-chip" data-v="crsh" role="button" tabindex="0" aria-label="Crash"><span class="v-label">CRSH</span><span class="v-name">Crash</span></div>
        <div class="voice-chip" data-v="ride" role="button" tabindex="0" aria-label="Ride"><span class="v-label">RIDE</span><span class="v-name">Ride</span></div>
        <div class="voice-chip" data-v="smpl" role="button" tabindex="0" aria-label="Sampler"><span class="v-label">SMPL</span><span class="v-name">Sampler</span></div>
      </div>
    </div>
    <div class="feat-visual" style="flex-direction:column;gap:12px">
      <!-- Engine viewer -->
      <div class="engine-viewer" id="engine-viewer">
        <div class="ev-header">
          <span class="ev-voice-name" id="ev-name">Wavetable</span>
          <span class="ev-voice-cat" id="ev-cat">SYNTH</span>
        </div>
        <div class="ev-graph-area" id="ev-graph-area">
          <svg id="ev-graph" viewBox="0 0 480 100" fill="none"></svg>
        </div>
        <div class="ev-knobs" id="ev-knobs"></div>
      </div>
    </div>
  </section>

  <!-- ── Feature 2: Graphical Sequencer ── -->
  <section class="feat-section">
    <!-- Boundary 1: cushion + crosshair + border square + star — Voices→SceneGraph — right -->
    <svg class="section-geo" style="right:6%;top:-75px;width:240px;height:180px" viewBox="0 0 240 180" aria-hidden="true">
      <!-- Cushion (concave square) — primary -->
      <path d="M55,18 Q95,38 135,18 Q115,58 135,98 Q95,78 55,98 Q75,58 55,18Z" fill="#1E2028"/>
      <!-- Rotated border square — overlapping lower -->
      <rect x="110" y="75" width="60" height="60" fill="none" stroke="#1E2028" stroke-width="1.5" transform="rotate(12 140 105)"/>
      <!-- Crosshair — upper right -->
      <g transform="translate(200,35)">
        <circle r="16" fill="none" stroke="#1E2028" stroke-width="1"/>
        <circle r="6" fill="none" stroke="#1E2028" stroke-width="0.8"/>
        <line x1="-22" y1="0" x2="22" y2="0" stroke="#1E2028" stroke-width="0.6"/>
        <line x1="0" y1="-22" x2="0" y2="22" stroke="#1E2028" stroke-width="0.6"/>
      </g>
      <!-- Thin arc connecting cushion to crosshair -->
      <path d="M140,55 Q175,20 195,55" fill="none" stroke="#1E2028" stroke-width="0.8"/>
      <!-- 4-point star -->
      <path d="M175,110 L179,122 L191,126 L179,130 L175,142 L171,130 L159,126 L171,122Z" fill="#1E2028"/>
      <!-- Accent dots -->
      <circle cx="35" cy="130" r="4" fill="#1E2028"/>
      <circle cx="220" cy="155" r="3" fill="#1E2028"/>
      <circle cx="25" cy="55" r="2" fill="#1E2028"/>
