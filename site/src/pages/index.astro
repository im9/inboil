      <div class="cta-row">
        <a id="app-link" class="cta primary" href={appUrl}>Open App</a>
        <a id="docs-link" class="cta" href="/docs/getting-started/first-beat/">Tutorial →</a>
      </div>
    </div>
    <div class="hero-visual">
