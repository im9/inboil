          g.appendChild(bar1);
          const bar2 = document.createElementNS(ns, 'rect');
          bar2.setAttribute('x', String(bx + bg/2));
          bar2.setAttribute('y', String(by - bh/2));
          bar2.setAttribute('width', String(bw));
          bar2.setAttribute('height', String(bh));
          bar2.setAttribute('rx', '0.8');
          bar2.setAttribute('fill', '#1E2028');
