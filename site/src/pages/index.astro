          <rect class="flap-cell" x="14" y="4" width="8" height="8" fill="#a3a145" opacity="0.5" style="--i:1"/>
          <rect class="flap-cell" x="4" y="14" width="8" height="8" fill="#a3a145" opacity="0.5" style="--i:2"/>
          <rect class="flap-cell" x="14" y="14" width="8" height="8" fill="#a3a145" style="--i:3"/>
          <rect x="24" y="4" width="4" height="18" rx="1" fill="#ede8dc" opacity="0.4"/>
        </svg>
