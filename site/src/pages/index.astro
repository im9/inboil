  })();

  // ── Interactive Scene Graph ──
  (() => {
    const svg = document.getElementById('scene-svg');
    const edgesG = document.getElementById('scene-edges');
    const nodesG = document.getElementById('scene-nodes');
    if (!svg || !edgesG || !nodesG) return;

    // Match app: scene-node { min-width:72px, height:32px, border-radius:0, font:9px 700 }
    const NW = 88, NH = 32;
    const edgeColor = 'rgba(30,32,40,0.18)';
    const ns = 'http://www.w3.org/2000/svg';

    const nodes = [
      { id:'intro', label:'Intro', x:80, y:104, color:'#787845', root:true },
      { id:'verse', label:'Verse', x:220, y:104, color:'#4472B4', playing:true },
      { id:'drop',  label:'Drop',  x:380, y:50, color:'#E8A090', deco:'T +5' },
      { id:'chill', label:'Chill', x:380, y:162, color:'#4A9B9B', deco:'RPT ×2' },
      { id:'outro', label:'Outro', x:540, y:104, color:'#9B6BA0' },
    ];

    const edges = [
      { from:'intro', to:'verse' },
      { from:'verse', to:'drop', order:0 },
      { from:'verse', to:'chill', order:1 },
      { from:'drop',  to:'outro' },
      { from:'chill', to:'outro' },
    ];

    function nodeById(id) { return nodes.find(n => n.id === id); }

    // Compute edge exit/entry points on node boundary (matches app sceneGeometry.ts)
    function edgePoints(s, d) {
      const hw = NW / 2, hh = NH / 2;
      const scx = s.x + hw, scy = s.y + hh;
      const dcx = d.x + hw, dcy = d.y + hh;
      const dx = dcx - scx, dy = dcy - scy;
      const dist = Math.hypot(dx, dy);
      if (dist < 1) return { sx: scx, sy: scy, dx: dcx, dy: dcy, angle: 0 };
      const nx = dx / dist, ny = dy / dist;
      // Ray-box intersection: find where direction exits each node rect
      const r0 = Math.min(hw / Math.max(Math.abs(nx), 0.01), hh / Math.max(Math.abs(ny), 0.01));
      const r1 = Math.min(hw / Math.max(Math.abs(nx), 0.01), hh / Math.max(Math.abs(ny), 0.01));
      return {
        sx: scx + nx * r0, sy: scy + ny * r0,
        dx: dcx - nx * r1, dy: dcy - ny * r1,
        angle: Math.atan2(ny, nx)
      };
    }

    function renderEdges() {
      edgesG.innerHTML = '';
      for (const e of edges) {
        const s = nodeById(e.from), d = nodeById(e.to);
        const ep = edgePoints(s, d);

        // Quadratic bezier with slight perpendicular offset (matches app)
        const mx = (ep.sx + ep.dx) / 2 + (ep.sy - ep.dy) * 0.15;
        const my = (ep.sy + ep.dy) / 2 - (ep.sx - ep.dx) * 0.15;
        const path = document.createElementNS(ns, 'path');
        path.setAttribute('d', `M${ep.sx},${ep.sy} Q${mx},${my} ${ep.dx},${ep.dy}`);
        path.setAttribute('stroke', edgeColor);
        path.setAttribute('stroke-width', '2');
        path.setAttribute('fill', 'none');
        edgesG.appendChild(path);

        // Triangle arrowhead (direction from control point to endpoint)
        const aAngle = Math.atan2(ep.dy - my, ep.dx - mx);
        const al = 7;
        const arr = document.createElementNS(ns, 'polygon');
        arr.setAttribute('points', [
          `${ep.dx},${ep.dy}`,
          `${ep.dx - al * Math.cos(aAngle - 0.4)},${ep.dy - al * Math.sin(aAngle - 0.4)}`,
          `${ep.dx - al * Math.cos(aAngle + 0.4)},${ep.dy - al * Math.sin(aAngle + 0.4)}`
        ].join(' '));
        arr.setAttribute('fill', edgeColor);
        edgesG.appendChild(arr);

        // Edge order label
        if (e.order !== undefined) {
          const lx = mx, ly = my;
          const bg = document.createElementNS(ns, 'rect');
          bg.setAttribute('x', String(lx - 8));
          bg.setAttribute('y', String(ly - 7));
          bg.setAttribute('width', '16');
          bg.setAttribute('height', '14');
          bg.setAttribute('fill', '#EDE8DC');
          bg.setAttribute('rx', '2');
          edgesG.appendChild(bg);
          const txt = document.createElementNS(ns, 'text');
          txt.setAttribute('x', String(lx));
          txt.setAttribute('y', String(ly + 4));
          txt.setAttribute('text-anchor', 'middle');
          txt.setAttribute('font-family', 'JetBrains Mono,monospace');
          txt.setAttribute('font-size', '11');
          txt.setAttribute('font-weight', '700');
          txt.setAttribute('fill', 'rgba(30,32,40,0.35)');
          txt.textContent = String(e.order);
          edgesG.appendChild(txt);
        }
      }
    }

    function renderNodes() {
      nodesG.innerHTML = '';
      for (const n of nodes) {
        const g = document.createElementNS(ns, 'g');
        g.setAttribute('data-node', n.id);
        g.style.cursor = 'grab';

        // Node rect — app: border-radius:0, border:1px solid rgba(30,32,40,0.1)
        // Root: border:2px solid #1E2028. Playing: border:1.5px solid rgba(255,255,255,0.75)
        const rect = document.createElementNS(ns, 'rect');
        rect.setAttribute('x', String(n.x));
        rect.setAttribute('y', String(n.y));
        rect.setAttribute('width', String(NW));
        rect.setAttribute('height', String(NH));
        rect.setAttribute('fill', n.color);
        if (n.root) {
          rect.setAttribute('stroke', '#1E2028');
          rect.setAttribute('stroke-width', '2');
        } else if (n.playing) {
          rect.setAttribute('stroke', 'rgba(255,255,255,0.75)');
          rect.setAttribute('stroke-width', '1.5');
          rect.classList.add('sn-playing');
        } else {
          rect.setAttribute('stroke', 'rgba(30,32,40,0.1)');
          rect.setAttribute('stroke-width', '1');
        }
        g.appendChild(rect);

        // Label — app: 9px 700 monospace, letter-spacing:0.04em
        const text = document.createElementNS(ns, 'text');
        text.setAttribute('x', String(n.x + NW / 2));
        text.setAttribute('y', String(n.y + NH / 2 + 4));
        text.setAttribute('text-anchor', 'middle');
        text.setAttribute('font-family', 'JetBrains Mono,monospace');
        text.setAttribute('font-size', '11');
        text.setAttribute('font-weight', '700');
        text.setAttribute('letter-spacing', '0.04em');
        text.setAttribute('fill', 'white');
        text.textContent = n.label;
        g.appendChild(text);

        // Edge handle (right side) — app: 10×10 circle, rgba(30,32,40,0.25)
        const hx = n.x + NW, hy = n.y + NH / 2;
        const handle = document.createElementNS(ns, 'circle');
        handle.setAttribute('cx', String(hx));
        handle.setAttribute('cy', String(hy));
        handle.setAttribute('r', '5');
        handle.setAttribute('fill', 'rgba(30,32,40,0.25)');
        handle.setAttribute('stroke', 'rgba(30,32,40,0.4)');
        handle.setAttribute('stroke-width', '1.5');
        g.appendChild(handle);

        // Decorator pill
        if (n.deco) {
          const pw = n.deco.length * 6 + 12;
          const px = n.x + NW / 2 - pw / 2;
          const py = n.y + NH + 4;
          const pill = document.createElementNS(ns, 'rect');
          pill.setAttribute('x', String(px));
          pill.setAttribute('y', String(py));
          pill.setAttribute('width', String(pw));
          pill.setAttribute('height', '16');
          pill.setAttribute('rx', '8');
          pill.setAttribute('fill', '#1E2028');
          g.appendChild(pill);
          const dt = document.createElementNS(ns, 'text');
          dt.setAttribute('x', String(n.x + NW / 2));
          dt.setAttribute('y', String(py + 11));
          dt.setAttribute('text-anchor', 'middle');
          dt.setAttribute('font-family', 'JetBrains Mono,monospace');
          dt.setAttribute('font-size', '8');
          dt.setAttribute('font-weight', '700');
          dt.setAttribute('fill', 'rgba(237,232,220,0.7)');
          dt.textContent = n.deco;
          g.appendChild(dt);
        }

        // Play button on top of everything (root only)
        if (n.root) {
          const bx = n.x - 4, by = n.y + NH / 2, br = 14;
          const shadow = document.createElementNS(ns, 'circle');
          shadow.setAttribute('cx', String(bx));
          shadow.setAttribute('cy', String(by + 1));
          shadow.setAttribute('r', String(br + 1));
          shadow.setAttribute('fill', 'rgba(30,32,40,0.1)');
          g.appendChild(shadow);
          const btn = document.createElementNS(ns, 'circle');
