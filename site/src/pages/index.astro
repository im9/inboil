---
const appUrl = import.meta.env.DEV ? 'http://localhost:5173' : 'https://inboil.pages.dev';
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>INBOIL</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    html,body{width:100%;height:100%;overflow:hidden;background:#1E2028}
    canvas#c{position:fixed;inset:0;width:100%;height:100%}
    .overlay{
      position:fixed;inset:0;
      display:flex;flex-direction:column;
      align-items:center;justify-content:center;
      pointer-events:none;z-index:1;
    }
    .tagline{
      margin-top:48px;
      font-family:"JetBrains Mono",monospace;
      font-size:0.6rem;letter-spacing:0.22em;
      text-transform:uppercase;
      color:rgba(237,232,220,0.25);
    }
    .cta-row{
      pointer-events:auto;
      display:flex;gap:0.8rem;
      margin-top:1.2rem;
    }
    .cta{
      padding:0.45rem 1.4rem;
      border:1px solid rgba(237,232,220,0.18);
      border-radius:4px;
      background:transparent;
      color:rgba(237,232,220,0.6);
      font-family:"JetBrains Mono",monospace;
      font-size:0.65rem;letter-spacing:0.12em;
      text-transform:uppercase;text-decoration:none;
      transition:all 0.25s;
    }
    .cta:hover{
      background:rgba(237,232,220,0.06);
      border-color:rgba(237,232,220,0.35);
      color:rgba(237,232,220,0.95);
    }
    .fallback-title{
      font-family:"Bebas Neue",sans-serif;
      font-size:4rem;letter-spacing:0.08em;
      color:rgba(237,232,220,0.85);
      display:none;
    }
    .no-gl .fallback-title{display:block}
    .no-gl canvas{display:none}
  </style>
</head>
<body>
  <canvas id="c"></canvas>
  <div class="overlay">
    <h1 class="fallback-title">INBOIL</h1>
    <p class="tagline">Browser Groove Box</p>
    <div class="cta-row">
      <a id="app-link" class="cta" href={appUrl}>Open App</a>
      <a id="docs-link" class="cta" href="/docs/getting-started/first-beat/">Get Started</a>
    </div>
  </div>

  <script is:inline>
  // Language
  (() => {
    const a = document.getElementById('docs-link');
    if (/^ja/i.test(navigator.language)) {
      a.href = '/ja/docs/getting-started/first-beat/';
      a.textContent = 'はじめる';
    }
  })();

  // Game of Life
  (() => {
    const canvas = document.getElementById('c');
    const gl = canvas.getContext('webgl2', { antialias: false, alpha: false });
    if (!gl) { document.body.classList.add('no-gl'); return; }

    const CELL = window.innerWidth > 768 ? 5000 : 3500;
    const SIM_EVERY = 3;
    let gridW, gridH, frame = 0;
    let mx = -100, my = -100, mActive = 0;

    // ── Shaders ──
    const VS = `#version 300 es
    in vec2 a_pos;
    void main(){gl_Position=vec4(a_pos,0,1);}`;

    const SIM_FS = `#version 300 es
    precision highp float;
    uniform sampler2D u_state, u_text;
    uniform vec2 u_grid, u_mouse;
    uniform float u_mouseActive, u_time;
    out vec4 o;
    float hash(vec2 p){return fract(sin(dot(p,vec2(12.9898,78.233)))*43758.5453);}
    void main(){
      vec2 uv=gl_FragCoord.xy/u_grid;
      vec2 px=1.0/u_grid;
      float st=texture(u_state,uv).r;
      float n=0.0;
      for(int dy=-1;dy<=1;dy++)
        for(int dx=-1;dx<=1;dx++){
          if(dx==0&&dy==0)continue;
          n+=step(0.5,texture(u_state,fract(uv+vec2(dx,dy)*px)).r);
        }
      float alive=step(0.5,st);
      float next=alive*step(1.5,n)*step(n,3.5)
                +(1.0-alive)*step(2.5,n)*step(n,3.5);
      float r=hash(gl_FragCoord.xy+u_time);
      float md=length(gl_FragCoord.xy-u_mouse);
      if(u_mouseActive>0.1&&md<14.0&&r>0.4) next=1.0;
      float txt=texture(u_text,vec2(uv.x,1.0-uv.y)).r;
      float breathe=0.92+0.05*sin(u_time*0.4);
      if(txt>0.5&&r>breathe) next=1.0;
      if(txt>0.5&&n>=1.5&&n<=3.5&&r>0.35) next=1.0;
      float val=next>0.5?1.0:st*0.86;
      o=vec4(val,0,0,1);
    }`;

    const RENDER_FS = `#version 300 es
    precision highp float;
    uniform sampler2D u_state;
    uniform vec2 u_grid;
    uniform float u_cell;
    out vec4 o;
    void main(){
      vec2 cell=floor(gl_FragCoord.xy/u_cell);
      vec2 ctr=(cell+0.5)*u_cell;
      float d=length(gl_FragCoord.xy-ctr);
      float st=texture(u_state,(cell+0.5)/u_grid).r;
      float maxR=u_cell*0.38;
      float rad=maxR*smoothstep(0.0,0.25,st);
      float dot=smoothstep(rad+0.6,rad-0.6,d);
      vec3 bg=vec3(0.118,0.125,0.157);
      vec3 cr=vec3(0.929,0.910,0.863);
      float a=dot*smoothstep(0.0,0.15,st)*0.85;
      o=vec4(mix(bg,cr,a),1);
    }`;

    // ── GL helpers ──
    function compile(type, src) {
      const s = gl.createShader(type);
      gl.shaderSource(s, src); gl.compileShader(s);
      if (!gl.getShaderParameter(s, gl.COMPILE_STATUS))
        console.error(gl.getShaderInfoLog(s));
      return s;
    }
    function link(vs, fs) {
      const p = gl.createProgram();
      gl.attachShader(p, vs); gl.attachShader(p, fs);
      gl.linkProgram(p); return p;
    }
    function makeFBO(w, h, data) {
      const tex = gl.createTexture();
      gl.bindTexture(gl.TEXTURE_2D, tex);
      gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA8, w, h, 0, gl.RGBA, gl.UNSIGNED_BYTE, data);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.NEAREST);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.NEAREST);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.REPEAT);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.REPEAT);
      const fbo = gl.createFramebuffer();
      gl.bindFramebuffer(gl.FRAMEBUFFER, fbo);
      gl.framebufferTexture2D(gl.FRAMEBUFFER, gl.COLOR_ATTACHMENT0, gl.TEXTURE_2D, tex, 0);
      return { tex, fbo };
    }

    const vsS = compile(gl.VERTEX_SHADER, VS);
    const simProg = link(vsS, compile(gl.FRAGMENT_SHADER, SIM_FS));
    const renProg = link(vsS, compile(gl.FRAGMENT_SHADER, RENDER_FS));

    // Quad VAO
    const vao = gl.createVertexArray();
    gl.bindVertexArray(vao);
    const qb = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, qb);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1,1,-1,-1,1,1,1]), gl.STATIC_DRAW);
    const aP = gl.getAttribLocation(simProg, 'a_pos');
    gl.enableVertexAttribArray(aP);
    gl.vertexAttribPointer(aP, 2, gl.FLOAT, false, 0, 0);

    // Uniforms
    const simU = {
      state: gl.getUniformLocation(simProg, 'u_state'),
      text:  gl.getUniformLocation(simProg, 'u_text'),
      grid:  gl.getUniformLocation(simProg, 'u_grid'),
      mouse: gl.getUniformLocation(simProg, 'u_mouse'),
      mAct:  gl.getUniformLocation(simProg, 'u_mouseActive'),
      time:  gl.getUniformLocation(simProg, 'u_time'),
    };
    const renU = {
      state: gl.getUniformLocation(renProg, 'u_state'),
      grid:  gl.getUniformLocation(renProg, 'u_grid'),
      cell:  gl.getUniformLocation(renProg, 'u_cell'),
    };

    let fbos, textTex;

    function buildTextMask() {
      const tc = document.createElement('canvas');
      tc.width = gridW; tc.height = gridH;
      const ctx = tc.getContext('2d');
      ctx.fillStyle = '#000';
      ctx.fillRect(0, 0, gridW, gridH);
      // Auto-fit "INBOIL"
      ctx.font = '100px "Bebas Neue","Arial Black",sans-serif';
      const scale = (gridW * 0.5) / ctx.measureText('INBOIL').width;
      const fs = Math.floor(100 * scale);
      ctx.font = `${fs}px "Bebas Neue","Arial Black",sans-serif`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillStyle = '#fff';
      ctx.fillText('INBOIL', gridW / 2, gridH / 2 - gridH * 0.04);
      return tc;
    }

    function init() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      gridW = Math.ceil(canvas.width / CELL);
      gridH = Math.ceil(canvas.height / CELL);

      // Text mask
      const tc = buildTextMask();
      const tctx = tc.getContext('2d');
      const tpx = tctx.getImageData(0, 0, gridW, gridH).data;

      // Upload text texture (no flip — shader flips UV)
      textTex = gl.createTexture();
      gl.bindTexture(gl.TEXTURE_2D, textTex);
      gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA8, gl.RGBA, gl.UNSIGNED_BYTE, tc);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.NEAREST);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.NEAREST);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
      gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);

      // Seed state — denser in text region
      const data = new Uint8Array(gridW * gridH * 4);
      for (let gy = 0; gy < gridH; gy++) {
        for (let gx = 0; gx < gridW; gx++) {
          const cy = gridH - 1 - gy; // canvas Y (top=0) for GL Y (bottom=0)
          const inText = tpx[(cy * gridW + gx) * 4] > 128;
          const density = inText ? 0.55 : 0.12;
          const i = (gy * gridW + gx) * 4;
          data[i] = Math.random() < density ? 255 : 0;
          data[i + 3] = 255;
        }
      }
      fbos = [makeFBO(gridW, gridH, data), makeFBO(gridW, gridH, data)];
      frame = 0;
    }

    // ── Input ──
    canvas.addEventListener('pointermove', e => {
      mx = e.clientX / CELL;
      my = (canvas.height - e.clientY) / CELL;
      mActive = 1;
    });
    canvas.addEventListener('pointerleave', () => { mActive = 0; });
    canvas.addEventListener('touchmove', e => { e.preventDefault(); }, { passive: false });

    // ── Loop ──
    function tick(t) {
      requestAnimationFrame(tick);
      const time = t * 0.001;

      // Decay mouse activity
      if (mActive > 0) mActive *= 0.97;

      // Simulation step (throttled)
      if (frame % SIM_EVERY === 0) {
        const src = fbos[0], dst = fbos[1];
        gl.bindFramebuffer(gl.FRAMEBUFFER, dst.fbo);
        gl.viewport(0, 0, gridW, gridH);
        gl.useProgram(simProg);
        gl.activeTexture(gl.TEXTURE0);
        gl.bindTexture(gl.TEXTURE_2D, src.tex);
        gl.uniform1i(simU.state, 0);
        gl.activeTexture(gl.TEXTURE1);
        gl.bindTexture(gl.TEXTURE_2D, textTex);
        gl.uniform1i(simU.text, 1);
        gl.uniform2f(simU.grid, gridW, gridH);
        gl.uniform2f(simU.mouse, mx, my);
        gl.uniform1f(simU.mAct, mActive);
        gl.uniform1f(simU.time, time);
        gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
        fbos[0] = dst; fbos[1] = src;
      }

      // Render
      gl.bindFramebuffer(gl.FRAMEBUFFER, null);
      gl.viewport(0, 0, canvas.width, canvas.height);
      gl.useProgram(renProg);
      gl.activeTexture(gl.TEXTURE0);
      gl.bindTexture(gl.TEXTURE_2D, fbos[0].tex);
      gl.uniform1i(renU.state, 0);
      gl.uniform2f(renU.grid, gridW, gridH);
      gl.uniform1f(renU.cell, CELL);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);

      frame++;
    }

    // Wait for fonts then start
    document.fonts.ready.then(() => {
      init();
      requestAnimationFrame(tick);
    });

    // Resize
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(init, 200);
    });
  })();
  </script>
</body>
</html>
